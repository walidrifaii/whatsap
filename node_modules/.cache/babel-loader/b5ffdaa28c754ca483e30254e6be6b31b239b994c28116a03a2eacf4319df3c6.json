{"ast":null,"code":"import{create}from'zustand';import{getMe}from'../services/api';const useAuthStore=create(set=>({user:null,token:localStorage.getItem('token'),loading:true,setAuth:(token,user)=>{localStorage.setItem('token',token);set({token,user,loading:false});},logout:()=>{localStorage.removeItem('token');set({token:null,user:null,loading:false});},loadUser:async()=>{const token=localStorage.getItem('token');if(!token){set({loading:false});return;}try{const{data}=await getMe();set({user:data.user,loading:false});}catch{localStorage.removeItem('token');set({token:null,user:null,loading:false});}}}));export default useAuthStore;","map":{"version":3,"names":["create","getMe","useAuthStore","set","user","token","localStorage","getItem","loading","setAuth","setItem","logout","removeItem","loadUser","data"],"sources":["C:/Users/DELL/Desktop/applications/whatsapp-saas/whatsapp-saas/frontend/src/store/authStore.js"],"sourcesContent":["import { create } from 'zustand';\nimport { getMe } from '../services/api';\n\nconst useAuthStore = create((set) => ({\n  user: null,\n  token: localStorage.getItem('token'),\n  loading: true,\n\n  setAuth: (token, user) => {\n    localStorage.setItem('token', token);\n    set({ token, user, loading: false });\n  },\n\n  logout: () => {\n    localStorage.removeItem('token');\n    set({ token: null, user: null, loading: false });\n  },\n\n  loadUser: async () => {\n    const token = localStorage.getItem('token');\n    if (!token) {\n      set({ loading: false });\n      return;\n    }\n    try {\n      const { data } = await getMe();\n      set({ user: data.user, loading: false });\n    } catch {\n      localStorage.removeItem('token');\n      set({ token: null, user: null, loading: false });\n    }\n  }\n}));\n\nexport default useAuthStore;\n"],"mappings":"AAAA,OAASA,MAAM,KAAQ,SAAS,CAChC,OAASC,KAAK,KAAQ,iBAAiB,CAEvC,KAAM,CAAAC,YAAY,CAAGF,MAAM,CAAEG,GAAG,GAAM,CACpCC,IAAI,CAAE,IAAI,CACVC,KAAK,CAAEC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,CACpCC,OAA